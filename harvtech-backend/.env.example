# Database Configuration
# For PostgreSQL (Production - e.g., Render):
# DATABASE_URL=postgresql://username:password@hostname:port/database_name
# For PostgreSQL on Render specifically:
# DATABASE_URL=postgresql://user:password@dpg-xxxxx.postgres.render.com:5432/dbname

# For SQLite (Local Development - default if DATABASE_URL is not set):
# DATABASE_URL=sqlite:///./database.db
# Or just leave this unset to use the default SQLite database

# Authentication Configuration
SECRET_KEY=your-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
